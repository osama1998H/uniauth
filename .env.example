# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
ENVIRONMENT=development   # development | production

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://uniauth:uniauth@localhost:5432/uniauth?sslmode=disable

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Auth ─────────────────────────────────────────────────────────────────────
# REQUIRED: Generate with: openssl rand -base64 32
JWT_SECRET=

ACCESS_TOKEN_DURATION=15m
REFRESH_TOKEN_DURATION=168h    # 7 days
RESET_TOKEN_DURATION=1h
RATE_LIMIT_PER_MINUTE=60

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Use * for development, comma-separated origins for production:
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=*

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Leave SMTP_HOST empty to disable password reset email delivery safely.
# For local development, prefer MailHog via docker-compose.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# URL used in email links (e.g., password reset links)
APP_BASE_URL=http://localhost:3000
